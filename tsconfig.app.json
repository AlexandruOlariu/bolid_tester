{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2021", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "customConditions": ["react-native"],
    "types": ["node", "react", "react-native"],
    "allowJs": true,
    "noEmit": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noUnusedLocals": false
  },
  "//": "Full-app typecheck: `npm run typecheck:app`. Bundler resolution + react-native condition for RN deps.",
  "include": ["src/**/*.ts", "src/**/*.tsx", "tamagui.config.ts"],
  "exclude": ["node_modules", "**/*.test.ts"]
}
