{
  "name": "bolid-tester",
  "version": "0.1.0",
  "private": true,
  "description": "Generic OBD2/EOBD diagnostics app (React Native/Expo). Documentation-driven — see docs/.",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "typecheck:app": "tsc -p tsconfig.app.json --noEmit",
    "lint": "eslint \"src/shared/lib/**/*.ts\" \"src/shared/obd-core/**/*.ts\" \"src/shared/vehicles/**/*.ts\"",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"docs/**/*.md\""
  },
  "keywords": [
    "obd2",
    "elm327",
    "ble",
    "diagnostics",
    "react-native",
    "expo"
  ],
  "license": "MIT",
  "dependencies": {
    "@tamagui/config": "^1.144.4",
    "expo": "^56.0.9",
    "expo-dev-client": "~56.0.19",
    "expo-router": "~56.2.9",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-ble-plx": "^3.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "tamagui": "^1.144.4",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@tamagui/babel-plugin": "^1.144.4",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.0",
    "@types/react": "~19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "babel-preset-expo": "~56.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "typescript": "~6.0.3"
  },
  "_note": "Core tooling (ts/jest/eslint) is installed and verified in CI/container. The RN runtime deps require a native build; install on a dev machine with `npm install` (or `npx expo install` to align native versions) — see docs/phase2-mobile-app.md."
}
