// bolid-context curated overlay  —  hand-edited, survives refactors.
//
// This is the durable payoff: domain concepts and relationships that the code
// structure cannot express. Auto-derived edges (imports / serves / documents)
// are table-stakes; THIS file is what makes the graph smarter than grep.
// (29 concepts. Coverage goal: every non-trivial node has a concept neighbour.)
//
// Format:
//   concepts[]      { id, summary, tokens[] }      -> becomes a concept:<id> node
//   links[]         [a, b, "relates"]              -> a relates edge (rel optional)
//   summaries{}     { "node:id": "override text" } -> override a node's summary
//
// After editing, run:  python3 scripts/graph.py build   (the hook does this for you)
// Find exact node ids with:  python3 scripts/graph.py find <term>
{
  "concepts": [
    { "id": "connection-lifecycle",
      "summary": "Establishing a live link: BLE permission + scan -> BleTransport -> Elm327Client init (ATZ/ATSPn) -> DiagnosticSession; status flows into sessionStore.",
      "tokens": ["connection","connect","ble","bluetooth","lifecycle","elm327","session","pairing"] },
    { "id": "obd-request-pipeline",
      "summary": "How a read happens: command -> Elm327Client (waits for the '>' prompt) -> responseParser -> obd decoders (pids/dtc). The half-duplex request/response path.",
      "tokens": ["pipeline","request","response","command","decode","pid","elm327"] },
    { "id": "mock-simulator",
      "summary": "Offline/unit testing via a virtual ELM327: MockTransport replays scenarios so the whole stack runs with no hardware.",
      "tokens": ["mock","simulator","virtual","scenario","offline","test","fake"] },
    { "id": "dpf-regen",
      "summary": "DPF / regeneration interpretation from experimental manufacturer Mode 22 PIDs; turns raw soot/ash figures into status + advice. EXPERIMENTAL and vehicle-specific.",
      "tokens": ["dpf","regen","regeneration","soot","ash","diesel","particulate","mode22"] },
    { "id": "vehicle-profiles",
      "summary": "Per-car profiles drive supported PIDs and extended DIDs. Add a car = new profile in the registry + matching docs/vehicles/<id>.md (kept in sync by a test).",
      "tokens": ["vehicle","profile","car","registry","make","model","did","supported"] },
    { "id": "ecu-coding",
      "summary": "ECU coding / adaptations: writing DIDs over UDS. Higher-risk than reads — guarded paths live in the coding module.",
      "tokens": ["coding","uds","adaptation","write","ecu","did","long","code"] },
    { "id": "ai-diagnose-flow",
      "summary": "AI Diagnose: snapshot fault codes + live readings -> aiDiagnosis builds the prompt -> AI client (OpenAI-compatible) -> human-readable diagnosis.",
      "tokens": ["ai","diagnose","diagnosis","llm","openai","prompt","advice"] },
    { "id": "error-resilience",
      "summary": "Resilience pattern: recoverable failures are captured via logError into errorLogStore (the single logging zone, shown in the Error Log screen) rather than crashing the session.",
      "tokens": ["error","resilience","logging","recover","failure","fault","log"] },
    { "id": "state-architecture",
      "summary": "App state is zustand stores. sessionStore is the connection hub; persistStorage backs the durable ones (settings/history). Keep cross-cutting state here, not in features.",
      "tokens": ["state","store","zustand","persist","global","session","settings"] },
    { "id": "dtc-faults",
      "summary": "Diagnostic Trouble Codes: read/clear (Mode 03/07/0A) + readiness monitors. dtc.ts encodes/decodes the P/C/B/U codes shown in Fault Codes.",
      "tokens": ["dtc","fault","code","trouble","readiness","monitor","clear","mil"] },
    { "id": "vin-identify",
      "summary": "Vehicle identification: read VIN (Mode 09 PID 02) then decode to make/model/year — used to suggest a vehicle profile.",
      "tokens": ["vin","identify","decode","wmi","year","manufacturer"] },
    { "id": "live-data-charts",
      "summary": "Live telemetry: poll Mode 01 PIDs, ring-buffer samples (chartBuffer) and render gauges/charts. The hot path for live-data and live-charts.",
      "tokens": ["live","data","chart","gauge","stream","telemetry","buffer","poll"] },
    { "id": "threshold-alerts",
      "summary": "User-defined threshold rules on live PIDs (coolant overheat, boost, low battery, over-rev) fire visual/haptic/audible alerts via edge detection on the poll loop.",
      "tokens": ["alert","alerts","threshold","rule","overheat","boost","warn","haptic","limit"] },
    { "id": "battery-charging",
      "summary": "12V battery and charging-system health from system voltage: resting voltage -> state of charge, the cranking dip on start, alternator voltage running; good/fair/weak verdict.",
      "tokens": ["battery","charging","voltage","alternator","cranking","soc","12v","health"] },
    { "id": "extended-pids-mode22",
      "summary": "Profile-driven manufacturer-specific reads over Mode 22 (UDS readDataByIdentifier); VAG is the first example. Opt-in, experimental, flagged.",
      "tokens": ["extended","pid","mode22","uds","did","manufacturer","vag","experimental"] },
    { "id": "diagnostic-history",
      "summary": "On-device, file-backed history of every AI auto-diagnose run and fault-code check, each linked to a car (VIN or profile). Unlimited retention until cleared.",
      "tokens": ["history","past","record","persistent","car","retention","logbook"] },
    { "id": "used-car-inspection",
      "summary": "One-tap pre-purchase check: runs a standard OBD2 snapshot (readiness, DTCs) and returns a pass/caution/fail verdict with a per-check breakdown for non-experts.",
      "tokens": ["inspection","used","purchase","prepurchase","verdict","pass","fail","snapshot","buy"] },
    { "id": "maintenance-log",
      "summary": "Service logbook: record work + odometer/date, then compute what is due (oil, filters, timing belt, brake fluid, coolant, DPF) by distance and time; feeds reminders.",
      "tokens": ["maintenance","service","logbook","due","oil","filter","reminder","odometer","interval"] },
    { "id": "notifications-layer",
      "summary": "Single local-notification layer (no server/push): OS notifications + in-app banners fed by threshold alerts, connection/diagnostic events, and maintenance reminders.",
      "tokens": ["notification","notify","banner","local","reminder","event","quiet","hours"] },
    { "id": "performance-tests",
      "summary": "Performance runs from live OBD2 data: 0-100 km/h, custom intervals, standing quarter-mile/60ft, braking distance; built on the poll loop. The 'bolid' track companion.",
      "tokens": ["performance","acceleration","quarter","mile","braking","speed","launch","track","060"] },
    { "id": "sensor-monitoring",
      "summary": "Watch individual sensors live (wiggle/actuation test) and read standardized Mode 06 on-board monitor test results. Standard tier (any OBD2) + experimental CAN tier.",
      "tokens": ["sensor","sensors","mode06","monitor","wiggle","actuate","reading","readings","onboard"] },
    { "id": "service-reset",
      "summary": "Reset the service interval / oil-service reminder (SRI). It writes to a control module, so it carries the same gating/guardrails as ECU coding.",
      "tokens": ["service","reset","sri","oil","reminder","interval","write","gated"] },
    { "id": "vehicle-info",
      "summary": "Show vehicle + adapter identity: ELM327/adapter info, the active protocol, ECU(s), and supported-PID coverage for the connected car.",
      "tokens": ["vehicle","info","adapter","identity","ecu","protocol","supported","about"] },
    { "id": "trip-recording",
      "summary": "Record a drive as a typed time-series of live PIDs (+ DTC snapshots), persist/replay/export it. Decoded data for analysis, unlike the raw adapter I/O log.",
      "tokens": ["trip","recording","drive","timeseries","replay","export","csv","journey"] },
    { "id": "app-settings",
      "summary": "Runtime + developer settings: units, behavior toggles, and the raw adapter I/O log (bytes for debugging). Backed by settingsStore.",
      "tokens": ["settings","config","units","preferences","developer","io","options","toggle"] },
    { "id": "app-shell",
      "summary": "Expo-router app shell: the root _layout (navigation/tabs) and the More tab — a hub listing secondary screens (history, maintenance, settings, etc.).",
      "tokens": ["navigation","nav","layout","tab","shell","more","menu","router","routing","home","drawer"] },
    { "id": "shared-ui-kit",
      "summary": "Shared Tamagui UI components reused across screens: Screen (scroll + pull-to-refresh frame), Gauge and ValueCard (live readouts), StatusBadge (connection state), AppLogo.",
      "tokens": ["ui","component","components","tamagui","gauge","card","valuecard","badge","statusbadge","widget","reusable","svg"] },
    { "id": "mobile-build-adapter",
      "summary": "Building/running the app: Expo dev-client + local Gradle APK (see the android-apk skill), and the reference BLE adapter (Vgate iCar Pro) used for bring-up.",
      "tokens": ["build","apk","gradle","expo","android","mobile","adapter","vgate","icar","install","run","devclient"] },
    { "id": "documentation-driven",
      "summary": "Documentation-driven workflow: docs/ is the source of truth. PLAN is the approved plan, implementation-log tracks progress, architecture.md is the map, every feature has a doc.",
      "tokens": ["documentation","docs","plan","process","implementation","log","readme","architecture","spec","sourceoftruth"] }
  ],
