{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "ignoreDeprecations": "6.0",
    "lib": [
      "ES2020"
    ],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noUnusedLocals": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "declaration": false,
    "noEmit": true,
    "types": [
      "node",
      "jest"
    ],
    "resolveJsonModule": true,
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "//": "Scoped to the platform-agnostic core (tested in the container). The RN app is typechecked with tsconfig.app.json on a dev machine.",
  "include": [
    "src/shared/lib/**/*.ts",
    "src/shared/obd-core/**/*.ts",
    "src/shared/vehicles/**/*.ts"
  ],
  "extends": "expo/tsconfig.base"
}
